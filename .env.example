# Environment variables for docker-compose
# Copy this to .env and fill in your actual values

# Railway PostgreSQL Database URL
# Get this from your Railway project's postgres service
DATABASE_URL=postgresql://user:password@host.railway.app:port/database

# Tavily Search API (get free key at https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# OpenRouter API (get free key at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model to use (default: openai/gpt-3.5-turbo)
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Enable automated scheduler (runs every 6 hours)
ENABLE_SCHEDULER=false
